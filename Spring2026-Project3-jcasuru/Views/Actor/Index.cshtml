@model IEnumerable<Spring2026_Project3_jcasuru.Models.Actor>

@{
    ViewData["Title"] = "Actor Index";
}

<h1>Actor Index</h1>

<p>
    <a asp-action="Create" asp-controller="Actor">Create New Actor</a>
</p>
<table class="table table-striped" data-table>
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Gender)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Age)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IMDB_Link)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Gender)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Age)
                </td>
                <td>
                    <a href="@item.IMDB_Link" target="_blank">IMDB Link</a>
                </td>
                <td>
                    <a asp-action="Edit" asp-controller="Actor" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-controller="Actor" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-controller="Actor" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
